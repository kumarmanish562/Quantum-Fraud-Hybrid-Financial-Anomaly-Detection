# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/fraud_detection
DATABASE_URL_TEST=postgresql://username:password@localhost:5432/fraud_detection_test

# Redis Configuration (for real-time features)
REDIS_URL=redis://localhost:6379

# JWT Configuration
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Quantum Fraud Detection API
VERSION=1.0.0

# ML Model Paths
MODEL_PATH=../ml_engine/saved_models/
CLASSICAL_MODEL_PATH=../ml_engine/saved_models/classical_model.joblib
HYBRID_MODEL_PATH=../ml_engine/saved_models/quantum_hqnn.pth

# Environment
ENVIRONMENT=development
DEBUG=True

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]